# Atlas local development settings.
# Copy this file to .env and fill OPENAI_API_KEY locally.

OPENAI_API_KEY=

ATLAS_DATABASE_URL=postgresql+psycopg://atlas:atlas@localhost:15432/atlas
ATLAS_QDRANT_URL=http://localhost:6333
ATLAS_QDRANT_COLLECTION=atlas_chunks_bge_small_zh_v1_5

ATLAS_EMBEDDING_PROVIDER=local
ATLAS_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
ATLAS_EMBEDDING_DIM=512
ATLAS_EMBEDDING_BATCH_SIZE=16

ATLAS_LLM_PROVIDER=openai
ATLAS_LLM_MODEL=gpt-5-nano
ATLAS_LLM_TIMEOUT_SECONDS=60
ATLAS_LLM_MAX_OUTPUT_TOKENS=2000
ATLAS_LLM_REASONING_EFFORT=low

ATLAS_DEFAULT_TOP_K=8
ATLAS_MAX_TOP_K=12
ATLAS_MAX_CONTEXT_TOKENS=6000
ATLAS_DOCUMENT_ROOTS=samples,corpus

# V1 FinanceBench hybrid settings.
# Use a separate collection because hybrid collections use named dense vectors plus BM25 sparse vectors.
# ATLAS_QDRANT_COLLECTION=atlas_financebench_v1
# ATLAS_RETRIEVAL_MODE=hybrid
# ATLAS_BM25_ENABLED=true
# ATLAS_BM25_MODEL=Qdrant/bm25
# ATLAS_BM25_LANGUAGE=english
# ATLAS_BM25_K=1.2
# ATLAS_BM25_B=0.75
# ATLAS_BM25_AVG_LEN=256.0
# ATLAS_RERANKER_ENABLED=true
# ATLAS_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
# ATLAS_RERANKER_TOP_K=30
# ATLAS_RERANKER_OUTPUT_K=8
# ATLAS_CACHE_ENABLED=false
